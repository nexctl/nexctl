FROM golang:1.25-alpine

RUN apk add --no-cache git build-base

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# 编译为固定路径，避免与 compose 中 ./server:/app 挂载冲突（挂载只覆盖 /app，不覆盖 /usr/local/bin）
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /usr/local/bin/nexctl-server ./cmd/server

EXPOSE 8080

WORKDIR /app

CMD ["/usr/local/bin/nexctl-server", "-config", "configs/config.example.yaml"]
